generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  university_manager
  student
}

model User {
  id             Int       @id @default(autoincrement())
  fullName       String
  email          String    @unique
  password       String
  role           UserRole  @default(student)
  graduationYear Int
  timeZone       String
  universityId   Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}