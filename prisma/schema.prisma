generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  university_manager
  student
}

model User {
  id             Int         @id @default(autoincrement())
  fullName       String
  email          String      @unique
  password       String
  role           UserRole    @default(student)
  graduationYear Int
  timeZone       String
  universityId   String?
  university     University? @relation(fields: [universityId], references: [id])
  teamMemberships TeamMember[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model University {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  teams     Team[]
  tournaments Tournament[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id           Int          @id @default(autoincrement())
  name         String
  bio          String?
  logo         String?
  universityId String
  createdBy    Int
  university   University   @relation(fields: [universityId], references: [id])
  members      TeamMember[]
  tournamentEntries TournamentTeam[] @relation
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId     Int
  userId     Int
  team       Team    @relation(fields: [teamId], references: [id])
  user       User    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([teamId, userId])
}

model Tournament {
  id                   Int              @id @default(autoincrement())
  name                 String
  type                 String
  registrationDeadline DateTime
  startDate            DateTime
  endDate              DateTime
  universityId         String
  bracketType          String
  description          String
  rules                String
  timeZone             String
  status               String           @default("draft")
  university           University       @relation(fields: [universityId], references: [id])
  registrations        TournamentTeam[]
  matches              Match[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model TournamentTeam {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  teamId       Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, teamId])
}

model Match {
  id            Int        @id @default(autoincrement())
  tournamentId  Int
  team1Id       Int
  team2Id       Int
  scheduledTime DateTime
  roundNumber   Int
  matchNumber   Int
  status        String     @default("scheduled")
  winnerId      Int?
  nextMatchId   Int?
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}